# Auto detect text files and perform LF normalization
* text=auto
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Windows files
*.{cmd,[cC][mM][dD]} text eol=crlf
*.{bat,[bB][aA][tT]} text eol=crlf

# Golden output files are compared byte-for-byte by the test harness:
# never apply EOL conversion (Windows checkouts turned LF goldens into
# CRLF and every golden comparison failed on windows runners).
*.golden -text
go.mod merge=union
go.sum merge=union
