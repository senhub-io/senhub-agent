{
  "uid": "senhub-ibmi-security",
  "title": "SenHub IBM i — Security (awaiting live data)",
  "tags": ["senhub", "agents", "ibmi"],
  "timezone": "browser",
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "IBM i system",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(senhub_ibmi_user_profile_count, service_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 1, "title": "Headline", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
    {
      "type": "stat", "id": 10, "title": "User profiles",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_ibmi_user_profile_count{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background_solid" }
    },
    {
      "type": "stat", "id": 11, "title": "Users with failed signons",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_ibmi_user_profile_failed_signons{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "type": "stat", "id": 12, "title": "QSECURITY level",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "max(senhub_ibmi_sysval_security_level{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 40 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "type": "stat", "id": 13, "title": "QAUDLVL (audit level)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "max(senhub_ibmi_sysval_audit_level{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background_solid" }
    },
    { "type": "row", "id": 2, "title": "Users by class", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "panels": [] },
    {
      "type": "table", "id": 20, "title": "User profile distribution by class",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum by(ibmi_user_class) (senhub_ibmi_user_profile_by_class{service_name=~\"$service\"})", "legendFormat": "{{ibmi_user_class}}", "format": "table", "instant": true }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "displayName", "value": "User count" }] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "User count", "desc": true }] }
    },
    {
      "type": "table", "id": 21, "title": "Watch sessions",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_ibmi_watch_session_active{service_name=~\"$service\"}", "legendFormat": "{{ibmi_watch_session_id}}", "format": "table", "instant": true }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Active" }, { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "inactive", "color": "red" }, "1": { "text": "active", "color": "green" } } }] }] }
        ]
      },
      "options": { "showHeader": true }
    },
    { "type": "row", "id": 3, "title": "Trends", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }, "panels": [] },
    {
      "type": "timeseries", "id": 30, "title": "User profiles by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum by(ibmi_user_status) (senhub_ibmi_user_profile_by_status{service_name=~\"$service\"})", "legendFormat": "{{ibmi_user_status}}" }],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 15, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } }
    },
    {
      "type": "timeseries", "id": 31, "title": "Users with failed signons over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_ibmi_user_profile_failed_signons{service_name=~\"$service\"})", "legendFormat": "failed signons" }],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    }
  ],
  "schemaVersion": 39, "version": 1
}
