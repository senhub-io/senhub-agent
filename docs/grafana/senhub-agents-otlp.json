{
  "uid": "senhub-agents-otlp",
  "title": "SenHub Agents — OTLP push (sha901 / sha501)",
  "tags": ["senhub-intake", "otlp", "agents"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Server",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(system_memory_usage_bytes, service_name)",
        "regex": "/sha\\d{3}-prod/",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "iface",
        "label": "Network interface",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(system_network_io_bytes_total{service_name=~\"$service\"}, network_interface_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Memory used",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_memory_utilization_ratio{service_name=~\"$service\",system_memory_state=\"used\"}",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "CPU utilization (user+system)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(service_name) (system_cpu_utilization_ratio{service_name=~\"$service\",cpu_mode=~\"user|system|nice\"})",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Load average (1m)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_linux_cpu_load_1m{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "id": 13,
      "title": "Filesystem max % used",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "max by(service_name) (system_filesystem_utilization_ratio{service_name=~\"$service\",system_filesystem_state=\"used\"})",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "id": 2,
      "title": "CPU",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "CPU utilization by mode",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_cpu_utilization_ratio{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} / {{cpu_mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "none", "group": "A" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Load average",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "refId": "A", "expr": "system_linux_cpu_load_1m{service_name=~\"$service\"}",  "legendFormat": "{{service_name}} 1m" },
        { "refId": "B", "expr": "system_linux_cpu_load_5m{service_name=~\"$service\"}",  "legendFormat": "{{service_name}} 5m" },
        { "refId": "C", "expr": "system_linux_cpu_load_15m{service_name=~\"$service\"}", "legendFormat": "{{service_name}} 15m" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "row",
      "id": 3,
      "title": "Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 30,
      "title": "Memory usage by state",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_memory_usage_bytes{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} / {{system_memory_state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries",
      "id": 31,
      "title": "Memory utilization ratio (used / limit)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_memory_utilization_ratio{service_name=~\"$service\",system_memory_state=\"used\"}",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "row",
      "id": 4,
      "title": "Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 40,
      "title": "Network throughput per interface (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, network_interface_name, network_io_direction) (rate(system_network_io_bytes_total{service_name=~\"$service\",network_interface_name=~\"$iface\"}[1m]))",
          "legendFormat": "{{service_name}} / {{network_interface_name}} / {{network_io_direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Packet errors + drops (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, network_interface_name) (rate(system_network_errors_total{service_name=~\"$service\",network_interface_name=~\"$iface\"}[1m]))",
          "legendFormat": "{{service_name}} / {{network_interface_name}} errors"
        },
        {
          "refId": "B",
          "expr": "sum by (service_name, network_interface_name) (rate(system_network_packet_dropped_total{service_name=~\"$service\",network_interface_name=~\"$iface\"}[1m]))",
          "legendFormat": "{{service_name}} / {{network_interface_name}} dropped"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } }
    },
    {
      "type": "row",
      "id": 5,
      "title": "Filesystem",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 50,
      "title": "Filesystem utilization (used %)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_filesystem_utilization_ratio{service_name=~\"$service\",system_filesystem_state=\"used\"}",
          "legendFormat": "{{service_name}} {{system_filesystem_mountpoint}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red",    "value": 0.95 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "type": "timeseries",
      "id": 51,
      "title": "Inode utilization (ratio)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "senhub_system_filesystem_inode_utilization_ratio{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} {{system_filesystem_mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "row",
      "id": 6,
      "title": "Logs (journald via linux_logs probe)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "panels": []
    },
    {
      "type": "logs",
      "id": 60,
      "title": "Recent logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 43 },
      "datasource": { "type": "victorialogs-datasource", "uid": "victorialogs" },
      "targets": [
        {
          "refId": "A",
          "expr": "service.name:~\"$service\"",
          "queryType": "logsql",
          "datasource": { "type": "victorialogs-datasource", "uid": "victorialogs" }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "weekStart": ""
}
