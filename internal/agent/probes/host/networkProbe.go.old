package host

import (
	"context"
	"fmt"
	"time"
	"net"

  "senhub-agent.go/internal/agent/probes/types"
	"senhub-agent.go/internal/agent/services/data_store"
	"senhub-agent.go/internal/agent/services/logger"
	"senhub-agent.go/internal/agent/services/common"

	psnet "github.com/shirou/gopsutil/v3/net"


)

type networkProbe struct {
	rawConfig map[string]interface{}
	logger    *logger.Logger
}

func NewNetworkProbe(config map[string]interface{}, logger *logger.Logger) (types.Probe, error) {
	// No validation needed for this probe
	return &networkProbe{
		rawConfig: config,
		logger:    logger,
	}, nil
}

func (m *networkProbe) GetName() string {
	return "host_network"
}

func (m *networkProbe) ShouldStart() bool {
	return true
}

func (m *networkProbe) GetInterval() time.Duration {
	return 30 * time.Second
}

func (m *networkProbe) Collect() ([]data_store.DataPoint, error) {
    timestamp := time.Now()

    // Get common host tags
    baseTags, err := common.GetHostTags()
    if err != nil {
        return nil, fmt.Errorf("error getting host tags: %v", err)
    }

    // Get active interfaces using standard net package
    interfaces, err := net.Interfaces()
    if err != nil {
        return nil, fmt.Errorf("error getting network interfaces: %v", err)
    }

    // Filter valid interfaces
    validInterfaces := make(map[string]bool)
    for _, iface := range interfaces {
        // Skip loopback interfaces and interfaces that are not up
        if iface.Flags&net.FlagLoopback != 0 || iface.Flags&net.FlagUp == 0 {
            continue
        }

        // Check if interface has an IP address
        addrs, err := iface.Addrs()
        if err != nil {
            continue
        }

        if len(addrs) > 0 {
            validInterfaces[iface.Name] = true
        }
    }

    // Get network statistics using gopsutil
    netStats, err := psnet.IOCounters(true) // true to get stats per interface
    if err != nil {
        return nil, fmt.Errorf("error getting network metrics: %v", err)
    }

    var dataPoints []data_store.DataPoint

    // For each network interface
    for _, netStat := range netStats {
        // Process only valid interfaces
        if !validInterfaces[netStat.Name] {
            continue
        }

        // Add traffic metrics with interface name as prefix
        dataPoints = append(dataPoints,
            // Bytes
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_bytes_sent", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.BytesSent),
                Tags:      baseTags,
            },
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_bytes_recv", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.BytesRecv),
                Tags:      baseTags,
            },
            // Packets
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_packets_sent", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.PacketsSent),
                Tags:      baseTags,
            },
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_packets_recv", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.PacketsRecv),
                Tags:      baseTags,
            },
            // Errors
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_errors_in", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.Errin),
                Tags:      baseTags,
            },
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_errors_out", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.Errout),
                Tags:      baseTags,
            },
            // Dropped packets
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_dropped_in", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.Dropin),
                Tags:      baseTags,
            },
            data_store.DataPoint{
                Name:      fmt.Sprintf("%s_dropped_out", netStat.Name),
                Timestamp: timestamp,
                Value:     float32(netStat.Dropout),
                Tags:      baseTags,
            },
        )
    }

    return dataPoints, nil
}

func (m *networkProbe) OnStart(quitChannel chan struct{}) error {
	return nil
}
func (m *networkProbe) OnShutdown(ctx context.Context) error {
	return nil
}
