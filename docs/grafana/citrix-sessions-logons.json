{
  "uid": "senhub-citrix-sessions-logons",
  "title": "SenHub Citrix VDI — Sessions & Logons (awaiting live data)",
  "tags": ["senhub", "agents", "citrix"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Citrix endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(senhub_citrix_sessions_count, service_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 1, "title": "Headline", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
    {
      "type": "stat", "id": 10, "title": "Active sessions",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_citrix_sessions_count{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background_solid" }
    },
    {
      "type": "stat", "id": 11, "title": "Sessions opened (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_citrix_logon_sessions_opened{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "type": "stat", "id": 12, "title": "Failed sessions (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_citrix_connection_failures_total{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 20 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "type": "stat", "id": 13, "title": "Avg logon duration (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "avg(senhub_citrix_logon_duration_1h_average{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 30 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "area" }
    },
    { "type": "row", "id": 2, "title": "Trends", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "panels": [] },
    {
      "type": "timeseries", "id": 20, "title": "Active sessions over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_citrix_sessions_count{service_name=~\"$service\"}", "legendFormat": "{{service_name}}" }],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries", "id": 21, "title": "Logon phase durations",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_citrix_logon_phase_duration{service_name=~\"$service\"}", "legendFormat": "{{senhub_citrix_logon_phase}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    { "type": "row", "id": 3, "title": "Failures", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "panels": [] },
    {
      "type": "timeseries", "id": 30, "title": "Connection failures by category (rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "rate(senhub_citrix_connection_failures_by_category{service_name=~\"$service\"}[$__rate_interval])", "legendFormat": "{{senhub_citrix_failure_category}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } }
    }
  ],
  "schemaVersion": 39, "version": 1
}
