<?xml version="1.0" encoding="UTF-8"?>
<!--
  SenHub Agent — Windows MSI source (WiX Toolset v4+).

  Build (cross-platform, requires the WiX dotnet tool + the Windows
  binary staged at $(BinDir)\senhub-agent.exe):

      wix build packaging/windows/senhub-agent.wxs ^
        -d Version=0.2.0 ^
        -d BinDir=dist\windows-amd64 ^
        -arch x64 ^
        -ext WixToolset.Util.wixext ^
        -out dist\senhub-agent-0.2.0-amd64.msi

  The MSI installs senhub-agent.exe into %ProgramFiles%\SenHub Agent\,
  registers the "senhub-agent" Windows service (matching the kardianos
  service.Config Name in cmd/agent/service.go), and supports silent
  install with parametric configuration. The agent is OFFLINE by default
  (local scrape endpoints); the only provisionable fields are the license
  token (paid probe tiers) and host tags — there is no cloud backend or
  auth token to seed:

      msiexec /i senhub-agent.msi /qn ^
        LICENSE_KEY=eyJhbGci... ^
        TAGS=site=paris,env=prod

  See docs/deployment/windows-msi.md for GPO / SCCM / Intune deployment.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!--
    The UpgradeCode MUST remain stable across all versions so that
    major upgrades (clean replace of an older MSI) are detected.
    NEVER regenerate this GUID once shipped.
  -->
  <?define UpgradeCode = "8E0E0B5C-2C8F-4C4B-9E2A-1B0D7F9A6C31" ?>
  <?define ServiceName = "senhub-agent" ?>
  <?define ServiceDisplayName = "SenHub Agent" ?>
  <?define ServiceDescription = "SenHub Agent Service for monitoring and management" ?>

  <Package
      Name="SenHub Agent"
      Manufacturer="Sensor Factory"
      Version="$(Version)"
      UpgradeCode="$(UpgradeCode)"
      Scope="perMachine"
      Compressed="yes"
      InstallerVersion="500">

    <!-- Embed the cabinet inside the MSI so a single file ships. -->
    <MediaTemplate EmbedCab="yes" />

    <!--
      Clean major-upgrade story: a newer MSI removes the older product
      first, then installs. Config under %ProgramData%\SenHub is NOT
      owned by the MSI (see comment on the config component), so it
      survives the upgrade automatically.
    -->
    <MajorUpgrade
        DowngradeErrorMessage="A newer version of [ProductName] is already installed."
        Schedule="afterInstallInitialize" />

    <!--
      Block a colliding FOREIGN install with clear guidance. Proceed when:
      this is maintenance/uninstall (Installed), our own prior MSI is
      present (MSI_MARKER), the box is clean (no EXISTING_SERVICE), or the
      operator opted into migration (ADOPT). Otherwise stop with a message
      rather than fail obscurely on ServiceInstall.
    -->
    <Launch
        Condition="Installed OR MSI_MARKER OR NOT EXISTING_SERVICE OR ADOPT"
        Message="A SenHub Agent installed outside this installer was detected (the 'senhub-agent' Windows service already exists). Uninstall it first, or re-run this installer with ADOPT=1 to migrate it to MSI management — your configuration under %ProgramData%\SenHub is preserved." />

    <!-- ============================================================ -->
    <!-- Parametric configuration via public MSI properties.          -->
    <!-- Public (uppercase) properties can be set on the msiexec       -->
    <!-- command line for silent / GPO / SCCM / Intune deployment.     -->
    <!-- ============================================================ -->
    <!--
      LICENSE_KEY unlocks paid probe tiers (Free needs none). TAGS is a
      comma-separated k=v list applied as host global_tags. There is no
      cloud backend/token: the agent is offline by default (see header).
    -->
    <Property Id="LICENSE_KEY" Secure="yes" Hidden="yes" />
    <Property Id="TAGS" Secure="yes" />
    <!-- Optional: push metrics/logs to an OTLP collector (host:port). -->
    <Property Id="OTLP_ENDPOINT" Secure="yes" />

    <!--
      Keep the license token out of the MSI log. Secure="yes" only lets a
      public property survive the transition to the deferred/system context
      — it does NOT redact it. A verbose install (/l*v) would otherwise
      record the LICENSE_KEY property value and the SeedConfig deferred
      custom-action data (the config-init command line embeds the token,
      see SetProperty below). In WiX v4/v5 the special MsiHiddenProperties
      property cannot be authored directly (WIX0070); redaction is expressed
      per element instead — Hidden="yes" on the LICENSE_KEY Property above,
      and HideTarget="yes" on the SeedConfig CustomAction below.
    -->

    <!-- ============================================================ -->
    <!-- Existing-install detection.                                  -->
    <!-- EXISTING_SERVICE is set when the senhub-agent Windows service -->
    <!-- is registered; MSI_MARKER is set when THIS installer ran      -->
    <!-- before. A service present WITHOUT our marker is a FOREIGN     -->
    <!-- install (kardianos / `agent install` / a ZIP deploy), which   -->
    <!-- would collide with our ServiceInstall — so we either block    -->
    <!-- with guidance or, with ADOPT=1, migrate it to MSI management. -->
    <!-- ============================================================ -->
    <Property Id="EXISTING_SERVICE">
      <RegistrySearch Id="FindAgentService" Root="HKLM"
                      Key="SYSTEM\CurrentControlSet\Services\senhub-agent"
                      Name="ImagePath" Type="raw" />
    </Property>
    <Property Id="MSI_MARKER">
      <RegistrySearch Id="FindMsiMarker" Root="HKLM"
                      Key="SOFTWARE\Sensor Factory\SenHub Agent"
                      Name="Version" Type="raw" />
    </Property>
    <!-- ADOPT=1 takes over a foreign install: stop + delete its service
         before installing ours, preserving %ProgramData%\SenHub config. -->
    <Property Id="ADOPT" Secure="yes" />

    <!--
      Seed %ProgramData%\SenHub\agent.yaml at install time, but ONLY when
      the file does not already exist — so an upgrade or reinstall
      preserves operator configuration (acceptance: "préserver config
      existante"). `config init` is itself idempotent (it no-ops on an
      existing config), so this is belt-and-braces.

      We invoke the installed binary's `config init` path rather than
      templating YAML inside the MSI, so the schema stays owned by the
      agent: it writes the default offline multi-file layout, then applies
      the license + tags. Validated on a real Windows host (see
      docs/deployment/windows-msi.md, "Config seeding").
    -->
    <SetProperty Id="SeedConfig"
                 Value="&quot;[INSTALLFOLDER]senhub-agent.exe&quot; config init --config-path &quot;[CommonAppDataFolder]SenHub\agent.yaml&quot; --license &quot;[LICENSE_KEY]&quot; --tags &quot;[TAGS]&quot; --otlp-endpoint &quot;[OTLP_ENDPOINT]&quot;"
                 Before="SeedConfig"
                 Sequence="execute"
                 Condition="NOT Installed" />

    <CustomAction Id="SeedConfig"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  HideTarget="yes"
                  Return="ignore" />

    <!--
      ADOPT migration: stop and delete the foreign service before our
      ServiceInstall creates ours, so the MSI takes over cleanly. Runs
      only when ADOPT is set, a foreign service exists, and it is not our
      own install. Config under %ProgramData%\SenHub is left intact.
    -->
    <SetProperty Id="AdoptExisting"
                 Value="cmd.exe /c &quot;sc stop senhub-agent &amp; sc delete senhub-agent&quot;"
                 Before="AdoptExisting"
                 Sequence="execute"
                 Condition="ADOPT AND EXISTING_SERVICE AND NOT MSI_MARKER AND NOT Installed" />

    <CustomAction Id="AdoptExisting"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Take over a foreign service before InstallServices creates ours. -->
      <Custom Action="AdoptExisting" Before="InstallServices"
              Condition="ADOPT AND EXISTING_SERVICE AND NOT MSI_MARKER AND NOT Installed" />
      <!-- After files are laid down, before the service starts. -->
      <Custom Action="SeedConfig" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <Feature Id="Main" Title="SenHub Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- ============================================================ -->
    <!-- Guided installer UI.                                          -->
    <!-- WixUI_InstallDir gives the standard wizard flow: Welcome →    -->
    <!-- EULA → install directory → ready → progress → finish. A       -->
    <!-- silent install (/qn) skips the UI entirely and drives the     -->
    <!-- same properties from the command line / transform.            -->
    <!--                                                               -->
    <!-- Entering LICENSE_KEY / TAGS / OTLP_ENDPOINT inside the wizard  -->
    <!-- (a custom dialog) is a follow-up validated interactively on   -->
    <!-- Windows; today those are set via properties (silent install), -->
    <!-- and a guided install lands the offline default.               -->
    <!-- ============================================================ -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="packaging/windows/license.rtf" />

    <!-- ============================================================ -->
    <!-- Install layout.                                              -->
    <!--   %ProgramFiles%\SenHub Agent\senhub-agent.exe  (binary)    -->
    <!--   %ProgramData%\SenHub\                          (config)    -->
    <!-- ============================================================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SenHub Agent" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAFOLDER" Name="SenHub" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents">

      <!-- The agent binary + the Windows service registration. -->
      <Component Id="AgentExe" Directory="INSTALLFOLDER" Guid="*">
        <File Id="SenHubAgentExe"
              Name="senhub-agent.exe"
              Source="$(BinDir)\senhub-agent.exe"
              KeyPath="yes" />

        <!--
          Register the Windows service. Name + DisplayName + Description
          mirror cmd/agent/service.go svcConfig so an MSI-installed
          service is indistinguishable from one created by
          `senhub-agent install`. ExecStart args match the offline-only
          model (0.2.0+): the run verb with the canonical config path.
        -->
        <ServiceInstall
            Id="SenHubAgentService"
            Name="$(ServiceName)"
            DisplayName="$(ServiceDisplayName)"
            Description="$(ServiceDescription)"
            Type="ownProcess"
            Start="auto"
            ErrorControl="normal"
            Account="LocalSystem"
            Arguments="run --config-path &quot;[CommonAppDataFolder]SenHub\agent.yaml&quot;"
            Vital="yes">
          <!-- Mirror the kardianos recovery policy: restart on failure. -->
          <util:ServiceConfig
              FirstFailureActionType="restart"
              SecondFailureActionType="restart"
              ThirdFailureActionType="restart"
              RestartServiceDelayInSeconds="10"
              ResetPeriodInDays="1" />
        </ServiceInstall>

        <!-- Start on install, stop+remove on uninstall. -->
        <ServiceControl
            Id="SenHubAgentServiceControl"
            Name="$(ServiceName)"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
      </Component>

      <!--
        Config directory ownership.

        The config file itself is intentionally NOT installed as an MSI
        File: if the MSI owned it, an uninstall would delete operator
        configuration and a repair would overwrite it. Instead the agent
        generates %ProgramData%\SenHub\agent.yaml on first service start
        (generateOfflineConfiguration in cmd/agent/service.go) seeded from
        the BACKEND_URL / AGENT_TOKEN properties via the WriteConfig custom
        action below. This keeps "clean uninstall" and "preserve config on
        upgrade" both true: the MSI removes only what it created.

        We register the directory as a component (with an empty keypath
        registry value) so the install is well-formed, but we do NOT mark
        the directory for removal — leftover operator config is preferred
        over data loss on uninstall (acceptance criterion: no orphan files
        OUTSIDE user preference; config is user preference).
      -->
      <Component Id="DataFolderMarker" Directory="DATAFOLDER" Guid="*">
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Sensor Factory\SenHub Agent"
                       Name="InstallFolder"
                       Type="string"
                       Value="[INSTALLFOLDER]"
                       KeyPath="yes" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Sensor Factory\SenHub Agent"
                       Name="Version"
                       Type="string"
                       Value="$(Version)" />
      </Component>

    </ComponentGroup>
  </Package>
</Wix>
