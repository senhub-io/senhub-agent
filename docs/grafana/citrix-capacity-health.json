{
  "uid": "senhub-citrix-capacity-health",
  "title": "SenHub Citrix VDI — Capacity & Health (awaiting live data)",
  "tags": ["senhub", "agents", "citrix"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Citrix endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(senhub_citrix_machines_total, service_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 1, "title": "Machines", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
    {
      "type": "stat", "id": 10, "title": "Machines total",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_citrix_machines_total{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background_solid" }
    },
    {
      "type": "stat", "id": 11, "title": "Machines in fault",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_citrix_machines_by_fault_state{service_name=~\"$service\",senhub_citrix_machine_fault_state!=\"none\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "type": "stat", "id": 12, "title": "Machines overloaded",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_citrix_machines_overloaded{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "type": "stat", "id": 13, "title": "License days remaining (grace)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "min(senhub_citrix_license_grace_time_remaining{service_name=~\"$service\"}) / 86400", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "d", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 7 }, { "color": "green", "value": 30 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "area" }
    },
    { "type": "row", "id": 2, "title": "States breakdown", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "panels": [] },
    {
      "type": "timeseries", "id": 20, "title": "Machines by registration state",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum by(senhub_citrix_machine_registration_state) (senhub_citrix_machines_by_registration_state{service_name=~\"$service\"})", "legendFormat": "{{senhub_citrix_machine_registration_state}}" }],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 15, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } }
    },
    {
      "type": "timeseries", "id": 21, "title": "Machines by fault state",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum by(senhub_citrix_machine_fault_state) (senhub_citrix_machines_by_fault_state{service_name=~\"$service\"})", "legendFormat": "{{senhub_citrix_machine_fault_state}}" }],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 15, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } }
    },
    { "type": "row", "id": 3, "title": "Load & licensing", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "panels": [] },
    {
      "type": "timeseries", "id": 30, "title": "Avg load index",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "avg(senhub_citrix_load_index_ratio{service_name=~\"$service\"})", "legendFormat": "{{service_name}}" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries", "id": 31, "title": "License: active vs peak concurrent users",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "refId": "A", "expr": "senhub_citrix_license_sessions_active{service_name=~\"$service\"}",         "legendFormat": "{{service_name}} active" },
        { "refId": "B", "expr": "senhub_citrix_license_peak_concurrent_users{service_name=~\"$service\"}",   "legendFormat": "{{service_name}} peak" },
        { "refId": "C", "expr": "senhub_citrix_license_unique_users{service_name=~\"$service\"}",           "legendFormat": "{{service_name}} unique" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } }
    }
  ],
  "schemaVersion": 39, "version": 1
}
