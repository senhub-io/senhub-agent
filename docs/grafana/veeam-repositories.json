{
  "uid": "senhub-veeam-repositories",
  "title": "SenHub Veeam — Repositories (awaiting live data)",
  "tags": ["senhub", "agents", "veeam"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Veeam server",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(senhub_veeam_repository_limit, service_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 1, "title": "Capacity", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
    {
      "type": "bargauge", "id": 10, "title": "Repository used %",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_veeam_repository_utilization{service_name=~\"$service\"}", "legendFormat": "{{senhub_veeam_repository_name}}", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "red", "value": 0.95 }] } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "type": "bargauge", "id": 11, "title": "Repository bytes used",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_veeam_repository_usage{service_name=~\"$service\",senhub_veeam_repository_state=\"used\"}", "legendFormat": "{{senhub_veeam_repository_name}}", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    { "type": "row", "id": 2, "title": "Trends", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 }, "panels": [] },
    {
      "type": "timeseries", "id": 20, "title": "Used / Free over time (stacked)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_veeam_repository_usage{service_name=~\"$service\"}", "legendFormat": "{{senhub_veeam_repository_name}} / {{senhub_veeam_repository_state}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries", "id": 21, "title": "Utilization ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "senhub_veeam_repository_utilization{service_name=~\"$service\"}", "legendFormat": "{{senhub_veeam_repository_name}}" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    { "type": "row", "id": 3, "title": "Infrastructure", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }, "panels": [] },
    {
      "type": "stat", "id": 30, "title": "Proxies (enabled / total)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "refId": "A", "expr": "sum(senhub_veeam_proxies{service_name=~\"$service\",senhub_veeam_proxies_state=\"enabled\"})", "legendFormat": "enabled" },
        { "refId": "B", "expr": "sum(senhub_veeam_proxies{service_name=~\"$service\",senhub_veeam_proxies_state=\"total\"})", "legendFormat": "total" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat", "id": 31, "title": "Servers (available / total)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "refId": "A", "expr": "sum(senhub_veeam_servers{service_name=~\"$service\",senhub_veeam_servers_state=\"available\"})",  "legendFormat": "available" },
        { "refId": "B", "expr": "sum(senhub_veeam_servers{service_name=~\"$service\",senhub_veeam_servers_state=\"total\"})", "legendFormat": "total" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat", "id": 32, "title": "License days remaining",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "min(senhub_veeam_license_days_remaining{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "unit": "d", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 7 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat", "id": 33, "title": "Restore points (total)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "refId": "A", "expr": "sum(senhub_veeam_object_restore_points{service_name=~\"$service\"})", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    }
  ],
  "schemaVersion": 39, "version": 1
}
