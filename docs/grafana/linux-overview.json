{
  "uid": "senhub-linux-overview",
  "title": "SenHub Linux — Overview",
  "tags": ["senhub", "agents", "linux"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Server",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(system_memory_usage_bytes{os=\"linux\"}, service_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(system_memory_usage_bytes{service_name=~\"$service\"}, service_instance_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Memory used",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_memory_utilization_ratio{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red",    "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "CPU utilization",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by(service_name) (system_cpu_utilization_ratio{service_name=~\"$service\"})",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red",    "value": 0.85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Load average (1m)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_linux_cpu_load_1m{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 4 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "id": 13,
      "title": "Filesystem max % used",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "max by(service_name) (system_filesystem_utilization_ratio{service_name=~\"$service\",system_filesystem_state=\"used\"})",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red",    "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "id": 2,
      "title": "CPU & Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "CPU utilization per core",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_cpu_utilization_ratio{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} / cpu{{cpu_logical_number}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Memory usage by state",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_memory_usage_bytes{service_name=~\"$service\",system_memory_state!=\"\"}",
          "legendFormat": "{{service_name}} / {{system_memory_state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "row",
      "id": 3,
      "title": "Filesystem & Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 30,
      "title": "Filesystem usage per mountpoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_filesystem_utilization_ratio{service_name=~\"$service\",system_filesystem_state=\"used\"}",
          "legendFormat": "{{service_name}} {{system_filesystem_mountpoint}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red",    "value": 0.95 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "type": "timeseries",
      "id": 31,
      "title": "Network throughput per interface",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, network_interface_name, network_io_direction) (rate(system_network_io_bytes_total{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} / {{network_interface_name}} / {{network_io_direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "row",
      "id": 4,
      "title": "Recent errors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "panels": []
    },
    {
      "type": "logs",
      "id": 40,
      "title": "Recent ERROR/FATAL logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "defqbr545b18gf" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "defqbr545b18gf" },
          "expr": "service.name:~\"$service\" AND severity:~\"ERROR|FATAL\"",
          "editorMode": "code",
          "queryType": "instant",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
